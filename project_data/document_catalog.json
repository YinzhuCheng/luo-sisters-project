{
  "version": "0.2-structured-assets",
  "entry_chain": [
    "AGENTS.md",
    "README.md",
    "docs/document_governance.md",
    "docs/content_map.md",
    "docs/browser_automation.md",
    "knowledge/navigation.html",
    "knowledge/assets.html or a linked child page"
  ],
  "rules": [
    "Markdown and HTML are both documentation.",
    "Internal maintenance documents are English.",
    "Public web copy is localized through locale or data files.",
    "Read HTML progressively with the project-doc-governance reader before opening raw HTML.",
    "Generated HTML is output, not the long-term editing source."
  ],
  "documents": [
    {
      "path": "AGENTS.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "agent entrypoint",
      "read_strategy": "read first",
      "children": ["README.md", "docs/document_governance.md", "docs/content_map.md"]
    },
    {
      "path": "README.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "human quick start",
      "read_strategy": "read after AGENTS.md",
      "children": ["docs/document_governance.md", "docs/browser_automation.md", "knowledge/navigation.html", "knowledge/assets.html"]
    },
    {
      "path": "docs/document_governance.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "documentation governance law",
      "read_strategy": "read before changing docs",
      "children": ["docs/content_map.md", "docs/browser_automation.md", "project_data/document_catalog.json", "skills/project-doc-governance/SKILL.md"]
    },
    {
      "path": "docs/browser_automation.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "browser automation setup",
      "read_strategy": "read before Playwright-based visual QA",
      "children": ["requirements-browser.txt", "tools/browser_smoke_check.py", "index.html", "knowledge/navigation.html"]
    },
    {
      "path": "docs/content_map.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "content hierarchy map",
      "read_strategy": "read before assuming content is missing",
      "children": ["knowledge/navigation.html", "knowledge/assets.html", "characters/qingyou.json", "characters/arisu.json", "logs/asset_registry.csv"]
    },
    {
      "path": "skills/project-doc-governance/SKILL.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "project skill entrypoint",
      "read_strategy": "use for doc inspection and governance tasks",
      "children": ["skills/project-doc-governance/references/document_governance.md", "skills/project-doc-governance/scripts/read_html_doc.py"]
    },
    {
      "path": "index.html",
      "type": "html",
      "language": "zh-CN",
      "generated": true,
      "source": "locales/zh-CN.json",
      "role": "Chinese public showcase",
      "read_strategy": "summarize with read_html_doc.py",
      "children": ["character_sheets/qingyou.html", "character_sheets/arisu.html", "knowledge/navigation.html", "knowledge/assets.html"]
    },
    {
      "path": "en/index.html",
      "type": "html",
      "language": "en",
      "generated": true,
      "source": "locales/en.json",
      "role": "English public showcase mirror",
      "read_strategy": "summarize with read_html_doc.py",
      "children": ["en/character_sheets/qingyou.html", "en/character_sheets/arisu.html", "en/knowledge/navigation.html", "en/knowledge/assets.html"]
    },
    {
      "path": "knowledge/navigation.html",
      "type": "html",
      "language": "zh-CN",
      "generated": true,
      "source": "project_data/knowledge_base.json",
      "role": "Chinese structured navigation page",
      "read_strategy": "summarize with read_html_doc.py --structure-mode; choose the next link by task",
      "children": ["knowledge/assets.html", "knowledge/characters.html", "knowledge/story.html", "knowledge/visual.html", "knowledge/workflow.html"]
    },
    {
      "path": "en/knowledge/navigation.html",
      "type": "html",
      "language": "en",
      "generated": true,
      "source": "project_data/knowledge_base.en.json",
      "role": "English structured navigation page",
      "read_strategy": "summarize with read_html_doc.py --structure-mode; choose the next link by task",
      "children": ["en/knowledge/assets.html", "en/knowledge/characters.html", "en/knowledge/story.html", "en/knowledge/visual.html", "en/knowledge/workflow.html"]
    },
    {
      "path": "knowledge/assets.html",
      "type": "html",
      "language": "zh-CN",
      "generated": true,
      "source": "characters/*.json + logs/asset_registry.csv",
      "role": "Chinese asset index",
      "read_strategy": "summarize with read_html_doc.py; use for path and asset lookup",
      "children": ["character_sheets/qingyou.html", "character_sheets/arisu.html", "characters/qingyou.json", "characters/arisu.json", "logs/asset_registry.csv"]
    },
    {
      "path": "en/knowledge/assets.html",
      "type": "html",
      "language": "en",
      "generated": true,
      "source": "characters/*.json + logs/asset_registry.csv",
      "role": "English asset index",
      "read_strategy": "summarize with read_html_doc.py; use for path and asset lookup",
      "children": ["en/character_sheets/qingyou.html", "en/character_sheets/arisu.html", "characters/qingyou.json", "characters/arisu.json", "logs/asset_registry.csv"]
    },
    {
      "path": "knowledge/index.html",
      "type": "html",
      "language": "zh-CN",
      "generated": true,
      "source": "project_data/knowledge_base.json",
      "role": "Chinese structured knowledge index",
      "read_strategy": "summarize with read_html_doc.py; follow one link at a time",
      "children": ["knowledge/navigation.html", "knowledge/assets.html", "knowledge/characters.html", "knowledge/story.html", "knowledge/visual.html", "knowledge/workflow.html"]
    },
    {
      "path": "en/knowledge/index.html",
      "type": "html",
      "language": "en",
      "generated": true,
      "source": "project_data/knowledge_base.en.json",
      "role": "English structured knowledge index",
      "read_strategy": "summarize with read_html_doc.py; follow one link at a time",
      "children": ["en/knowledge/navigation.html", "en/knowledge/assets.html", "en/knowledge/characters.html", "en/knowledge/story.html", "en/knowledge/visual.html", "en/knowledge/workflow.html"]
    },
    {
      "path": "workflows/asset_generation_workflow.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "asset production workflow",
      "read_strategy": "read before generating or validating assets",
      "children": ["workflows/agent_parallel_guide.md", "tools/validate_assets.py", "tools/remove_chroma_batch.py", "tools/crop_from_sheet.py"]
    },
    {
      "path": "workflows/agent_parallel_guide.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "parallel-agent ownership guide",
      "read_strategy": "read before assigning asset scopes",
      "children": ["logs/progress_updates.csv", "logs/issue_memory.csv", "logs/asset_registry.csv"]
    },
    {
      "path": "prompts/character_sheet_prompt_notes.md",
      "type": "markdown",
      "language": "en",
      "generated": false,
      "role": "character sheet prompt rules",
      "read_strategy": "read before writing or revising character prompts",
      "children": [
        "assets/characters/qingyou/prompts/asset_prompts.md",
        "assets/characters/arisu/prompts/asset_prompts.md"
      ]
    }
  ]
}
