{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://luo-sisters.local/harness/task_packet.schema.json",
  "title": "Harness Task Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "intent",
    "allowed_paths",
    "forbidden_paths",
    "inputs",
    "expected_outputs",
    "required_checks",
    "evidence_bundle",
    "handoff_notes"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["docs", "page", "asset", "maintenance"]
    },
    "intent": { "type": "string", "minLength": 1 },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean", "default": true }
        }
      }
    },
    "expected_outputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "required_checks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_dir", "report_schema", "artifact_expectations"],
      "properties": {
        "report_dir": { "type": "string", "minLength": 1 },
        "report_schema": { "type": "string", "minLength": 1 },
        "artifact_expectations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "handoff_notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
